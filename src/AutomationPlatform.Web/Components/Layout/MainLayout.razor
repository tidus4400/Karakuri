@inherits LayoutComponentBase
@implements IDisposable
@inject ApiSessionState Session
@inject NavigationManager Nav

<div class="app-shell @(sidebarOpen ? "sidebar-open" : "")">
    <aside class="app-sidebar">
        <div class="brand row between center-v">
            <div>
                <div class="brand-mark">K</div>
                <div class="brand-text">AutomationPlatform</div>
            </div>
            <button class="icon-btn mobile-only" @onclick="ToggleSidebar" aria-label="Toggle navigation">☰</button>
        </div>

        <nav class="nav-stack">
            <NavLink class="nav-link" href="/dashboard" Match="NavLinkMatch.All">Dashboard</NavLink>
            <NavLink class="nav-link" href="/flows">Flows</NavLink>
            <NavLink class="nav-link" href="/jobs">Jobs</NavLink>
            <NavLink class="nav-link" href="/blocks">Blocks</NavLink>
            @if (Session.IsAdmin)
            {
                <NavLink class="nav-link" href="/runners">Runners</NavLink>
                <NavLink class="nav-link" href="/tokens">Tokens</NavLink>
            }
        </nav>

        <div class="sidebar-footer stack gap-sm">
            @if (Session.IsAuthenticated)
            {
                <div class="muted small">@Session.CurrentUser?.Email</div>
                <StatusPill Text="@Session.CurrentUser?.Role" Tone="@(Session.IsAdmin ? "warn" : "info")" />
            }
            else
            {
                <div class="muted small">Not signed in</div>
            }
        </div>
    </aside>

    <header class="app-header row between center-v">
        <div class="row gap-sm center-v">
            <button class="icon-btn desktop-hidden" @onclick="ToggleSidebar" aria-label="Toggle navigation">☰</button>
            <div class="page-title">Automation Platform</div>
        </div>
        <div class="row gap-sm center-v">
            @if (Session.IsAuthenticated)
            {
                <AppButton Variant="ghost" OnClick="LogoutClick">Logout</AppButton>
            }
            else
            {
                <AppButton Variant="primary" OnClick="LoginClick">Login</AppButton>
            }
        </div>
    </header>

    <main class="app-main" @onclick="CloseSidebarOnMobile">
        @Body
    </main>
</div>

@code {
    private bool sidebarOpen;

    protected override void OnInitialized()
    {
        Session.Changed += SessionChanged;
    }

    public void Dispose()
    {
        Session.Changed -= SessionChanged;
    }

    private void SessionChanged() => InvokeAsync(StateHasChanged);

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    private void CloseSidebarOnMobile() => sidebarOpen = false;

    private Task LoginClick(MouseEventArgs _)
    {
        Nav.NavigateTo("/login");
        return Task.CompletedTask;
    }

    private Task LogoutClick(MouseEventArgs _)
    {
        Session.SetUser(null);
        Nav.NavigateTo("/login");
        return Task.CompletedTask;
    }
}
